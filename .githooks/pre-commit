#!/usr/bin/env bash
#
# llmhub pre-commit 훅 — docs/08-autonomy-protocol.md 를 강제한다.
# 활성화: git config core.hooksPath .githooks
#
# 사람이 승인한 문서 변경은 탈출구로 통과시킨다:
#   LLMHUB_DOC_EDIT_APPROVED=1 git commit ...
#
# 문서로만 있는 규칙은 합리화 앞에서 무력하다. 그래서 여기서 실제로 막는다.

set -uo pipefail

repo_root=$(git rev-parse --show-toplevel)
cd "$repo_root" || exit 1

staged=$(git diff --cached --name-only --diff-filter=ACMR)
[ -z "$staged" ] && exit 0

fail() {
	echo ""
	echo "  ✖ 커밋 차단: $1"
	echo ""
	exit 1
}

# ─────────────────────────────────────────────────────────────
# 1. 비밀정보 (SEC-3, 절대 규칙 6)
# ─────────────────────────────────────────────────────────────
secrets=$(echo "$staged" | grep -E '(^|/)\.env$|\.pem$|\.key$' || true)
if [ -n "$secrets" ]; then
	fail "비밀정보로 보이는 파일이 스테이징되었다 (SEC-3):
$(echo "$secrets" | sed 's/^/      /')"
fi

# ─────────────────────────────────────────────────────────────
# 2. 금지 토큰 — 테스트 무력화 (docs/08 D-4)
# ─────────────────────────────────────────────────────────────
test_files=$(echo "$staged" | grep -E '(^|/)src/test/.*\.(java|kt)$' || true)
if [ -n "$test_files" ]; then
	# 추가된 줄(+)만 검사한다. 기존 코드는 건드리지 않는다.
	# 주의: grep -v '^\+\+\+' 는 쓰지 말 것. GNU BRE에서 \+ 는 "1회 이상" 수량자라
	# 헤더가 아니라 +로 시작하는 모든 줄이 지워진다. 반드시 -E(ERE)로 쓴다.
	banned=$(git diff --cached -U0 --no-color -- $test_files \
		| grep -E '^\+' | grep -vE '^\+\+\+ ' \
		| grep -nE '@Disabled|@Ignore|assumeTrue|assumeFalse|xfail|\.skip\(' || true)
	if [ -n "$banned" ]; then
		fail "테스트를 무력화하는 토큰이 추가되었다 (docs/08 D-4):
$(echo "$banned" | sed 's/^/      /')
      테스트를 약화시켜 green을 만들지 않는다. 막히면 HALT하고 사람에게 묻는다."
	fi
fi

# ─────────────────────────────────────────────────────────────
# 3. 읽기 전용 문서 보호 (docs/08 F)
# ─────────────────────────────────────────────────────────────
if [ "${LLMHUB_DOC_EDIT_APPROVED:-0}" != "1" ]; then

	# 3a. 완전 읽기 전용: CLAUDE.md, docs/01~08
	locked=$(echo "$staged" | grep -E '^CLAUDE\.md$|^docs/0[1-8][^/]*\.md$' || true)
	if [ -n "$locked" ]; then
		fail "결정·거버넌스 문서는 에이전트가 고치지 않는다 (docs/08 F):
$(echo "$locked" | sed 's/^/      /')
      사실 오류를 발견했다면 코드는 의도대로 구현하고, 수정안은 OQ로 올린다.
      사람이 승인했다면: LLMHUB_DOC_EDIT_APPROVED=1 git commit ..."
	fi

	# 3b. 체크박스만 허용: docs/requirements/*, docs/00
	checkbox_only=$(echo "$staged" | grep -E '^docs/requirements/.*\.md$|^docs/00-.*\.md$' || true)
	for f in $checkbox_only; do
		# 추가/삭제된 실제 내용 줄만 뽑는다. 헤더는 `--- a/…` `+++ b/…` 형태이므로
		# 경로 접두사까지 포함해 정확히 제외한다(내용 줄을 실수로 지우지 않도록).
		changed=$(git diff --cached -U0 --no-color -- "$f" \
			| grep -E '^[+-]' | grep -vE '^(\+\+\+ b/|--- a/)' || true)
		# `- [ ]` → `- [x]` 외의 변경이 있는지 본다.
		offending=$(echo "$changed" | grep -vE '^[+-][[:space:]]*- \[( |x)\] ' || true)
		if [ -n "$offending" ]; then
			fail "$f 는 체크박스(- [ ] → - [x])만 고칠 수 있다 (docs/08 F):
$(echo "$offending" | head -5 | sed 's/^/      /')
      시나리오를 스스로 추가·수정하지 않는다. 제안은 OQ로 한다."
		fi
		# 체크 해제(- [x] → - [ ])는 진행을 되돌리는 것이므로 막는다.
		unchecked=$(echo "$changed" | grep -E '^\+[[:space:]]*- \[ \] ' || true)
		removed_checked=$(echo "$changed" | grep -E '^-[[:space:]]*- \[x\] ' || true)
		if [ -n "$unchecked" ] && [ -n "$removed_checked" ]; then
			fail "$f 에서 완료된 시나리오의 체크를 해제했다. 진행을 되돌리려면 사람의 승인이 필요하다."
		fi
	done
fi

# ─────────────────────────────────────────────────────────────
# 4. 테스트 — 백엔드 변경이 있으면 전체 스위트를 돌린다 (docs/08 D-5)
# ─────────────────────────────────────────────────────────────
if echo "$staged" | grep -qE '^backend/.*\.(java|kts|yml|properties)$'; then
	echo "  … backend 변경 감지. 전체 테스트를 실행한다."
	if ! (cd backend && ./gradlew test --console=plain -q); then
		fail "테스트가 실패했다. green이 아니면 커밋하지 않는다 (절대 규칙 7).
      테스트를 약화시켜 통과시키지 말 것. 3회 연속 Green 실패면 HALT다."
	fi
	echo "  ✔ 테스트 통과"
fi

if echo "$staged" | grep -qE '^frontend/.*\.(ts|tsx|json)$'; then
	echo "  … frontend 변경 감지. 타입 검사와 테스트를 실행한다."
	if [ ! -d frontend/node_modules ]; then
		echo "  … node_modules가 없다. 검사를 건너뛴다 (npm install 후 다시 커밋할 것)."
	else
		if ! (cd frontend && npx tsc --noEmit); then
			fail "프론트엔드 타입 검사가 실패했다."
		fi
		if ! (cd frontend && npm test --silent); then
			fail "프론트엔드 테스트가 실패했다. green이 아니면 커밋하지 않는다 (절대 규칙 7)."
		fi
		echo "  ✔ 타입 검사·테스트 통과"
	fi
fi

exit 0
