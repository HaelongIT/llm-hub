# llmhub 환경변수 예시 — 값은 전부 placeholder다.
# 실제 값은 .env 에 두고 절대 커밋하지 않는다 (SEC-3).
# 여기 모인 값들은 REL-4(설정 외부화)가 코드 하드코딩을 금지한 것들이다.

# ─── PostgreSQL (사용자·세션·이력·감사, S9) ───
POSTGRES_HOST=localhost
# 5432가 아니다. 로컬에 PostgreSQL이 설치되어 있으면 그쪽이 0.0.0.0:5432를 먼저
# 잡아, 호스트에서 나가는 연결이 컨테이너가 아니라 로컬 서버로 간다.
# 증상: "password authentication failed for user llmhub" (docs/LEARNINGS.md)
POSTGRES_PORT=5433
POSTGRES_DB=llmhub
POSTGRES_USER=llmhub
POSTGRES_PASSWORD=change-me

# ─── Elasticsearch (조각·벡터·메타, S9) ───
ES_URL=http://localhost:9200
# 운영 compose는 ES 보안을 켠다. 개발 override는 끄므로 비워 둬도 된다.
ES_USERNAME=elastic
ES_PASSWORD=change-me
# ES가 연결만 받고 응답하지 않으면 무한 대기다 (REL-1). Duration 문법(예: 5s, 30s).
ES_CONNECT_TIMEOUT=5s
ES_RESPONSE_TIMEOUT=30s

# ─── Keycloak (OIDC, S25) ───
# 백엔드가 8080을 쓰므로 compose는 Keycloak을 호스트 8081로 노출한다.
# KEYCLOAK_URL = 브라우저가 보는 외부 주소(로그인 리다이렉트·토큰 iss).
KEYCLOAK_URL=http://localhost:8081
# 프론트 BFF의 서버측 백채널(code→token·refresh·jwks)이 쓰는 내부 주소 (리뷰 B1). 운영 컨테이너에서
# 외부 URL은 자기 자신이라 도달 못 하므로 내부 서비스명으로 친다. dev는 프론트가 호스트에서 도므로 외부와
# 같게 둔다(미설정이면 KEYCLOAK_URL로 폴백). 운영 compose는 http://keycloak:8080으로 덮는다.
KEYCLOAK_INTERNAL_URL=http://localhost:8081
KEYCLOAK_REALM=llmhub
# 백엔드 JWT 검증 (R-16). issuer는 토큰의 iss(Keycloak 외부 호스트명)와 정확히 같아야 한다.
# audience는 토큰의 aud에 있어야 하는 값 — 프론트 클라이언트의 audience 매퍼가 realm-export.json에
# 선언적으로 있어 dev·운영 import 때 자동으로 걸린다(docker/keycloak/README.md).
KEYCLOAK_ISSUER=http://localhost:8081/realms/llmhub
JWT_AUDIENCE=llmhub-backend
# 프론트엔드(next-auth)가 Authorization Code Flow로 쓰는 클라이언트. 클라이언트 구조와 audience 매퍼는
# realm-export.json이 만든다. 배포별 값(시크릿·redirect)은 커밋하지 않고(SEC-3) bootstrap-dev.sh /
# bootstrap-prod.sh가 얹는다.
KEYCLOAK_CLIENT_ID=llmhub-frontend
KEYCLOAK_CLIENT_SECRET=change-me
# 로컬 compose 전용 관리자 계정 (운영 배포에서는 사용하지 않는다)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

# 개발용 사용자 비밀번호. ./docker/keycloak/bootstrap-dev.sh 가 이 값으로 계정을 만든다.
# dev-user → USER 역할 → 접근 태그 {public}
# dev-admin → ADMIN 역할 → 접근 태그 {public, restricted}
DEV_USER_PASSWORD=change-me
DEV_ADMIN_PASSWORD=change-me

# ─── LiteLLM Gateway (내부망 전용, S8-1 / E7) ───
# 코어는 게이트웨이 하나만 보고 모델명 파라미터만 전달한다. 라우팅은 게이트웨이 책임.
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=change-me

# ─── 채팅 백엔드 ───
# CHAT_MODEL 은 게이트웨이의 논리 이름(docker/litellm/config.yaml 의 model_name)이다.
# 뒷단이 무엇이든 코어는 이 이름만 안다. 그래서 뒷단 교체는 아래 세 줄로 끝난다.
CHAT_MODEL=chat
LITELLM_CHAT_BACKEND=ollama/qwen3:8b
LITELLM_CHAT_API_BASE=http://host.docker.internal:11434
LITELLM_CHAT_API_KEY=not-used-for-ollama
#
# 사내 원격 게이트웨이(예: DGX Spark의 LiteLLM, OpenAI 호환)로 보내려면 위 셋만 바꾼다.
# config.yaml 도 코드도 건드리지 않는다. 컨테이너 DNS가 사내 호스트명을 못 풀 수 있으니
# 안 되면 IP를 쓴다.
#   LITELLM_CHAT_BACKEND=openai/<원격이 노출하는 모델명>
#   LITELLM_CHAT_API_BASE=http://<spark-ip>:4000/v1
#   LITELLM_CHAT_API_KEY=<원격 Bearer 키>

# ─── 임베딩 백엔드 (S8-4 / E9) ───
# ⚠ EMBEDDING_MODEL 은 채팅과 성격이 다르다. 이 값이 **모든 조각의 메타데이터에 박히고**,
#   재색인 stale 판정이 이 이름으로 대상을 고른다. 그래서 실제 모델을 가리켜야 한다.
#
#   뒷단(LITELLM_EMBEDDING_BACKEND)을 바꾸면서 이 이름을 그대로 두면 stale 판정이 아무것도
#   못 잡고, 색인된 벡터와 질문 벡터가 다른 공간에 있게 되어 **에러 없이 검색이 무너진다.**
#   반드시 함께 바꾼다 — 이름·config.yaml 의 model_name·뒷단, 셋을 같이. 그리고 전체 재색인.
#   차원이 달라지면 재색인으로도 안 된다. 새 ES 인덱스가 필요하다 (E9).
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIM=1024
LITELLM_EMBEDDING_BACKEND=ollama/bge-m3
LITELLM_EMBEDDING_API_BASE=http://host.docker.internal:11434
LITELLM_EMBEDDING_API_KEY=not-used-for-ollama
# 게이트웨이가 연결만 받고 응답하지 않으면 무한 대기다 (REL-1). 임베딩은 조각 수에 비례해
# 오래 걸리므로 read는 넉넉하게. 값은 Duration 문법(예: 5s, 2m).
EMBEDDING_CONNECT_TIMEOUT=5s
EMBEDDING_READ_TIMEOUT=120s

# ─── 검색 (S11, S15, PERF-3 / E10, E16) ───
SEARCH_TOP_K=5
# chunk_text의 BM25 분석기. 바꾸면 새 인덱스가 필요하다(매핑은 인덱스 생성 시 고정).
# ES_INDEX_NAME을 함께 바꾸고 전체를 재색인한다. 차원 변경과 같은 성질이다 (E16).
SEARCH_ANALYZER=nori
# 하이브리드 선형결합 가중치. RRF로 교체 시 ResultMerger 뒤에서 바뀐다 (E10).
SEARCH_BM25_BOOST=1.0
SEARCH_VECTOR_BOOST=1.0

# ─── 채팅 컨텍스트 (S2, PERF-5 / E2) ───
CONTEXT_TURNS=5
# 토큰 '사이'의 유휴 상한(REL-1). 게이트웨이가 조용히 멈추면 이 시간 뒤 error로 스트림을 닫는다.
# 전체 응답 상한이 아니라 긴 답변은 잘리지 않는다. Duration 문법.
CHAT_STREAM_IDLE_TIMEOUT=60s

# ─── 원본 보관 (S16 / E14) ───
# 시스템이 경로를 생성한다. 사용자 파일명을 그대로 경로에 쓰지 않는다 (SEC-4).
FILE_STORAGE_ROOT=./data/documents

# ─── Rate Limiting (S10) ───
# v0는 자리만 있고 실질 정책이 없다.
RATE_LIMIT_ENABLED=false

# ─── 감사 (S5 / E5) ───
# full = 질문·응답 전문 기록, minimal = 최소 필드. 스키마 변경 없이 전환된다.
AUDIT_SCOPE=full

# ─── 프론트엔드 (Next.js BFF) ───
# 클라이언트는 BFF만 호출한다. 코어·ES·PG·LiteLLM은 내부망 전용 (SEC-1).
CORE_BASE_URL=http://localhost:8080
# next-auth(Auth.js) 세션 암호화 키. openssl rand -base64 32
AUTH_SECRET=change-me
AUTH_URL=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000

# ─── 배포 (docker-compose.yml = 운영 기준) ───
# 데이터 볼륨 루트. 검증용 스택을 격리해 띄울 때 바꾼다.
DATA_ROOT=./data
# 호스트에 노출되는 포트는 이 둘뿐이다 (SEC-1).
FRONTEND_PORT=3000
KEYCLOAK_PORT=8081
# Keycloak이 스스로를 소개하는 주소. 브라우저가 리다이렉트로 접근한다.
KEYCLOAK_HOSTNAME=http://localhost:8081

# ─── 서비스 메모리 상한 (리뷰 B3) ───
# cgroup 제한이 없으면 JVM(backend·keycloak, MaxRAMPercentage=75)이 호스트 전체 RAM의 75%를 힙 상한으로
# 잡아, 단일 호스트에 다중 JVM이 물리 메모리를 초과해 OOM-kill된다. 각 서비스에 상한을 두면 JVM이 그 몫
# 기준으로 잡힌다. 아래 기본값 합계 ~8GB는 **16GB급 단일 호스트** 가정이다(나머지는 OS + 호스트 Ollama).
# 호스트 사양에 맞게 조정한다. 값 문법: 1g, 512m 등.
POSTGRES_MEM_LIMIT=1g
ES_MEM_LIMIT=2g
KEYCLOAK_MEM_LIMIT=1g
LITELLM_MEM_LIMIT=1g
BACKEND_MEM_LIMIT=2g
FRONTEND_MEM_LIMIT=1g
