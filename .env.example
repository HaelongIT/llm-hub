# llmhub 환경변수 예시 — 값은 전부 placeholder다.
# 실제 값은 .env 에 두고 절대 커밋하지 않는다 (SEC-3).
# 여기 모인 값들은 REL-4(설정 외부화)가 코드 하드코딩을 금지한 것들이다.

# ─── PostgreSQL (사용자·세션·이력·감사, S9) ───
POSTGRES_HOST=localhost
# 5432가 아니다. 로컬에 PostgreSQL이 설치되어 있으면 그쪽이 0.0.0.0:5432를 먼저
# 잡아, 호스트에서 나가는 연결이 컨테이너가 아니라 로컬 서버로 간다.
# 증상: "password authentication failed for user llmhub" (docs/LEARNINGS.md)
POSTGRES_PORT=5433
POSTGRES_DB=llmhub
POSTGRES_USER=llmhub
POSTGRES_PASSWORD=change-me

# ─── Elasticsearch (조각·벡터·메타, S9) ───
ES_URL=http://localhost:9200

# ─── Keycloak (OIDC, S25) ───
# 백엔드가 8080을 쓰므로 compose는 Keycloak을 호스트 8081로 노출한다.
KEYCLOAK_URL=http://localhost:8081
KEYCLOAK_REALM=llmhub
KEYCLOAK_CLIENT_ID=llmhub-backend
KEYCLOAK_CLIENT_SECRET=change-me
# 로컬 compose 전용 관리자 계정 (운영 배포에서는 사용하지 않는다)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me

# ─── LiteLLM Gateway (내부망 전용, S8-1 / E7) ───
# 코어는 모델명 파라미터만 전달한다. 라우팅·페일오버는 게이트웨이 책임.
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=change-me
# LiteLLM이 호스트의 Ollama를 바라본다. 클라우드 모델만 쓰면 불필요하다.
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ─── 모델 고정 (S8-1, S8-4) ───
# 임베딩 모델과 차원은 색인·검색이 반드시 동일해야 한다.
# 변경하면 재색인이 필요하다 (E9). 차원 변경은 새 ES 인덱스가 필요하다.
CHAT_MODEL=placeholder-chat-model
EMBEDDING_MODEL=placeholder-embedding-model
EMBEDDING_DIM=1024

# ─── 검색 (S11, S15, PERF-3 / E10, E16) ───
SEARCH_TOP_K=5
SEARCH_ANALYZER=nori
# 하이브리드 선형결합 가중치. RRF로 교체 시 ResultMerger 뒤에서 바뀐다 (E10).
SEARCH_BM25_BOOST=1.0
SEARCH_VECTOR_BOOST=1.0

# ─── 채팅 컨텍스트 (S2, PERF-5 / E2) ───
CONTEXT_TURNS=5

# ─── 원본 보관 (S16 / E14) ───
# 시스템이 경로를 생성한다. 사용자 파일명을 그대로 경로에 쓰지 않는다 (SEC-4).
FILE_STORAGE_ROOT=./data/documents

# ─── Rate Limiting (S10) ───
# v0는 자리만 있고 실질 정책이 없다.
RATE_LIMIT_ENABLED=false

# ─── 감사 (S5 / E5) ───
# full = 질문·응답 전문 기록, minimal = 최소 필드. 스키마 변경 없이 전환된다.
AUDIT_SCOPE=full

# ─── 프론트엔드 (Next.js BFF) ───
# 클라이언트는 BFF만 호출한다. 코어·ES·PG·LiteLLM은 내부망 전용 (SEC-1).
CORE_BASE_URL=http://localhost:8080
# next-auth(Auth.js) 세션 암호화 키. openssl rand -base64 32
AUTH_SECRET=change-me
AUTH_URL=http://localhost:3000
FRONTEND_ORIGIN=http://localhost:3000
